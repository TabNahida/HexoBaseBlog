<%
    const toolsConfig = theme.tools || {};
    const toolItems = Object.values((toolsConfig && toolsConfig.items) || {}).filter((tool) => tool && tool.enable !== false);
%>
<div class="tool-page">
    <section class="tool-hero">
        <div class="tool-hero-copy">
            <p class="tool-eyebrow">TOOLBOX</p>
            <h1><%= page.title %></h1>
            <p>
                Pick a tool first, then jump into its own dedicated workspace. This index page stays lightweight,
                and every tool gets its own route, layout and interaction logic.
            </p>
        </div>
        <div class="tool-hero-meta">
            <div class="tool-meta-card">
                <span class="tool-meta-label">Mode</span>
                <strong>Tool Directory</strong>
                <p>Start here, then open each tool on its own page.</p>
            </div>
        </div>
    </section>

    <section class="tool-grid">
        <aside class="tool-catalog">
            <% if (toolsConfig.enable !== false && toolItems.length) { %>
            <% toolItems.forEach((tool) => { %>
            <a class="tool-panel tool-card tool-link-card" href="<%- url_for(tool.path || "/tools") %>">
                <div class="tool-card-header">
                    <span class="tool-card-icon">
                        <i class="fa-<%- (tool.icon && tool.icon.theme) || "solid" %> fa-<%- (tool.icon && tool.icon.name) || "toolbox" %>"></i>
                    </span>
                    <span class="tool-card-tag"><%= tool.status || "Ready" %></span>
                </div>
                <div class="tool-card-body">
                    <h2><%= tool.title || "Tool" %></h2>
                    <p><%= tool.description || "" %></p>
                </div>
            </a>
            <% }); %>
            <% } else { %>
            <div class="tool-panel tool-catalog-note">
                <p>No tools are enabled in <code>themes/particlex/_config.yml</code>.</p>
            </div>
            <% } %>
            <div class="tool-panel tool-catalog-note">
                <p>
                    More tools can be added as sibling pages under <code>/tools/...</code> without turning this
                    index page into a giant single-file app.
                </p>
            </div>
        </aside>
        <div class="tool-directory-panel">
            <div class="tool-panel tool-directory-copy">
                <p class="tool-panel-kicker">Flow</p>
                <h2>Select a tool, then enter its page</h2>
                <p>
                    <code>chatbox</code> now lives on its own route so the full workspace can be shaped around one tool,
                    instead of being squeezed into the catalog page.
                </p>
            </div>
        </div>
    </section>
</div>
